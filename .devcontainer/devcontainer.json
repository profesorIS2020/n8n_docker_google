{
  "name": "n8n University Class",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/n8n_docker_google",
  "forwardPorts": [5678],
  "portsAttributes": {
    "5678": {
      "label": "n8n Panel",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  }
}

