{
  "name": "n8n University Environment",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app", // Apuntamos al contenedor de Node, no al de n8n
  "workspaceFolder": "/workspace",
  "forwardPorts": [5678],
  "portsAttributes": {
    "5678": {
      "label": "n8n Dashboard",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "echo 'Entorno listo. n8n corriendo en el puerto 5678'"
}

