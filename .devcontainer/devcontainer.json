{
  "name": "n8n University Class",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "forwardPorts": ["n8n:5678"],
  "portsAttributes": {
    "n8n:5678": {
      "label": "n8n Panel",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "echo 'Entorno listo. n8n está operativo en el puerto 5678'"
}

