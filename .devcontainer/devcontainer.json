{
  "name": "n8n University Class",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app", // Muy importante: VS Code arranca en 'app'
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "forwardPorts": [5678],
  "portsAttributes": {
    "5678": {
      "label": "n8n Panel",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "echo 'Entorno listo. n8n está operativo en el puerto 5678'"
}

