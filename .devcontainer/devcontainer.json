{
  "name": "n8n University Class",
  "dockerComposeFile": "docker-compose.yml",
  "service": "n8n",
  "workspaceFolder": "/workspaces/n8n_docker_google",
  "forwardPorts": [5678],
  "portsAttributes": {
    "5678": {
      "label": "n8n Panel",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
